# ==============================================================================
# SyncPad Backend Configuration Example File
# ==============================================================================
# Instructions:
# 1. Copy this file and rename it to `.env` in the same directory:
#    cp .env.example .env
# 2. Update the variables below with your actual configurations.
# 3. Ensure this file is never committed to source control (it is ignored by .gitignore).
# ==============================================================================

# Server Configuration
PORT=5000
NODE_ENV=development

# Security Secrets (Generate strong random keys for production)
JWT_SECRET=super_secret_jwt_key_change_me_in_production_12345
COOKIE_SECRET=super_secret_cookie_key_change_me_in_production_12345

# Database Configuration
# Local SQLite database file path (relative to backend root, or absolute path)
DATABASE_URL=database.db

# CORS Configuration (Vercel Frontend URL or local development client)
# Multiple origins can be comma-separated if needed in the server CORS configuration.
# Example: https://sync-pad-frontend.vercel.app,http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Auto-Archive Configuration (in hours)
AUTO_ARCHIVE_HOURS=2
